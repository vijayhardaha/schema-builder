{
  "name": "@vijayhardaha/schema-builder",
  "version": "1.0.0-rc.6",
  "type": "module",
  "description": "Reusable Schema.org structured data utilities, types, and React components",
  "license": "MIT",
  "author": {
    "name": "Vijay Hardaha",
    "url": "https://github.com/vijayhardaha"
  },
  "keywords": [
    "schema.org",
    "json-ld",
    "seo",
    "structured-data",
    "nextjs",
    "react",
    "typescript",
    "schema-builder"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vijayhardaha/schema-builder.git"
  },
  "bugs": {
    "url": "https://github.com/vijayhardaha/schema-builder/issues"
  },
  "homepage": "https://github.com/vijayhardaha/schema-builder#readme",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint --ext .ts,.tsx,.js,.jsx,.mjs,.cjs .",
    "lint:fix": "eslint --fix --ext .ts,.tsx,.js,.jsx,.mjs,.cjs .",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,css,md}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "tsc": "tsc --noEmit",
    "prepare": "husky",
    "release": "release-it",
    "release:dry": "release-it --dry-run"
  },
  "dependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/compat": "^2.0.3",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "release-it": "^19.2.4",
    "schema-dts": "^2.0.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.1"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": false
    },
    "react-dom": {
      "optional": true
    }
  },
  "overrides": {
    "undici": "^7.0.0"
  }
}
