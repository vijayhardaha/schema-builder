// =======================================================================
// Typescript Configuration (Build)
// =======================================================================
// Purpose: Type-checking and module resolution for library build output,
//         generating declaration files and CommonJS/ESM compatible bundles.
// Docs: https://www.typescriptlang.org/tsconfig
// =======================================================================

{
  "compilerOptions": {
    // ----------------------------------------------------------------------
    // Target & libs
    // ----------------------------------------------------------------------
    // Use modern ECMAScript features supported by current runtimes
    "target": "ES2024",

    // Include DOM types and iterable helpers for browser-based code
    "lib": ["ES2024", "DOM", "DOM.Iterable"],

    // Use the modern React JSX transform
    "jsx": "react-jsx",

    // ----------------------------------------------------------------------
    // Module resolution
    // ----------------------------------------------------------------------
    // Use native ESM module syntax and Node-style resolution
    "module": "ESNext",
    "moduleDetection": "force",
    "moduleResolution": "bundler",

    // Disallow importing .ts files directly (required for build)
    "allowImportingTsExtensions": false,

    // Base directory for non-relative imports used by tooling
    "baseUrl": ".",

    // Map `@/*` to `./src/*` for cleaner absolute imports
    "paths": { "@/*": ["./src/*"] },

    // Allow importing JSON files as modules
    "resolveJsonModule": true,

    // Allow default interop for CommonJS modules when consuming CJS packages
    "esModuleInterop": true,

    // ----------------------------------------------------------------------
    // Compilation strategy
    // ----------------------------------------------------------------------
    // Preserve import/export syntax in output
    "verbatimModuleSyntax": true,

    // Emit JS files during build (required for library output)
    "noEmit": false,

    // Output directory for compiled files
    "outDir": "./dist",

    // Generate .d.ts declaration files
    "declaration": true,

    // Output directory for declaration files
    "declarationDir": "./dist",

    // Allow mixed JS/TS code during gradual migration
    "allowJs": true,

    // ----------------------------------------------------------------------
    // Type safety
    // ----------------------------------------------------------------------
    // Enable all strict type-checking options for safer code
    "strict": true,

    // Catch unused local variables and function parameters at compile time
    "noUnusedLocals": true,
    "noUnusedParameters": true,

    // Ensure all code paths return a value or explicitly return nothing
    "noImplicitReturns": true,

    // Require explicit handling of switch case fallthrough
    "noFallthroughCasesInSwitch": true,

    // Use modern class field semantics for better compatibility
    "useDefineForClassFields": true,

    // Skip deep type checks inside node_modules for performance
    "skipLibCheck": true,

    // Avoid case-sensitivity issues across filesystems
    "forceConsistentCasingInFileNames": true,

    // Enable faster iteration over collections
    "downlevelIteration": true
  },

  // ---- Includes ----
  // Source files to include in the build
  "include": ["src/**/*.ts", "src/**/*.tsx"],

  // ---- Excludes ----
  "exclude": ["node_modules", "dist", "coverage", "**/*.test.ts", "**/*.test.tsx"]
}
